# ---------------------------------------------------------------------------
# MovieTVScraperLists environment configuration
# Copy this file to ".env" and fill in your values. NEVER commit your real .env
# ---------------------------------------------------------------------------

# Port the web app + API listen on (inside the container)
PORT=8088

# Where runtime data is stored (scraped libraries + saved login sessions).
# In Docker this is mounted as a volume so your logins survive restarts.
DATA_DIR=./data

# A long random string used to encrypt saved login sessions at rest.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Optional password to protect the whole web UI (basic gate). Leave blank to disable.
APP_PASSWORD=

# Playwright: keep true for servers. Set false only for local debugging with a screen.
HEADLESS=true

# Comma-separated providers to enable. Others stay hidden in the UI.
# Available: fandango,moviesanywhere,appletv,googleplay,primevideo
ENABLED_PROVIDERS=fandango,moviesanywhere,appletv,googleplay,primevideo
